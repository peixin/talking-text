# Copy to .env.deploy and fill in real values; .env.deploy is gitignored.

# Aliyun Container Registry
# Used as image repository AND as Docker Hub mirror (e.g. registry.cn-hangzhou.aliyuncs.com)
ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_NAMESPACE=your-namespace

# Remote server (must be configured in ~/.ssh/config)
SERVER_HOST=stillume
SERVER_DIR=/opt/apps/talking-text

# Domain configuration
DOMAIN_NAME=talking-text.stillume.com

# PostgreSQL password (written to .env on the server; also set in .env.app DATABASE_URL)
POSTGRES_PASSWORD=change-me-in-production
