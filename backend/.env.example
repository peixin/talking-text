# Copy to backend/.env and fill in real values; .env is gitignored.

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
DATABASE_URL=postgresql+asyncpg://talking_text:talking_text@localhost:5432/talking_text

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Session ---
SESSION_SECRET=change-me-in-production

# --- Volcengine Ark (LLM, OpenAI-compatible endpoint) ---
VOLC_ARK_API_KEY=
VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_ARK_MODEL=doubao-seed-2-0-mini-260215

# --- Volcengine Speech (STT + TTS share the same credentials) ---
# Get from console.volcengine.com/speech (语音技术 console).
# # https://console.volcengine.com/speech/
VOLC_SPEECH_APP_ID=
VOLC_SPEECH_ACCESS_KEY=

# --- TTS: Doubao-语音合成-2.0 ---
VOLC_TTS_RESOURCE_ID=seed-tts-2.0
VOLC_TTS_DEFAULT_VOICE=zh_female_yingyujiaoxue_uranus_bigtts
VOLC_TTS_AUDIO_FORMAT=mp3
VOLC_TTS_SAMPLE_RATE=24000

# --- STT: Doubao-流式语音识别-2.0 (bigmodel_nostream) ---
# Resource IDs: hourly=volc.seedasr.sauc.duration  concurrent=volc.seedasr.sauc.concurrent
VOLC_STT_RESOURCE_ID=volc.seedasr.sauc.duration
VOLC_STT_MODEL_NAME=bigmodel
VOLC_STT_SAMPLE_RATE=16000

# --- Audio Storage ---
# V1: store under local filesystem so kids can review later. V2: switch to TOS.
AUDIO_STORAGE_ENABLED=true
AUDIO_STORAGE_DIR=./tmp/audio

# --- Volcengine TOS (deferred to V2) ---
# TOS_ENDPOINT=
# TOS_REGION=
# TOS_BUCKET=
# TOS_ACCESS_KEY=
# TOS_SECRET_KEY=
