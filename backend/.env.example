# 复制到 backend/.env 并按需修改；.env 被 gitignore

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
DATABASE_URL=postgresql+asyncpg://talking_text:talking_text@localhost:5432/talking_text

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Session ---
SESSION_SECRET=change-me-in-production

# --- 火山方舟 LLM (豆包) ---（接入 adapter 时填入）
# DOUBAO_API_KEY=
# DOUBAO_MODEL=
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# --- 火山引擎 STT ---（接入 adapter 时填入）
# VOLC_STT_APP_ID=
# VOLC_STT_ACCESS_TOKEN=

# --- 火山引擎 TTS ---（接入 adapter 时填入）
# VOLC_TTS_APP_ID=
# VOLC_TTS_ACCESS_TOKEN=
# VOLC_TTS_VOICE_TYPE=

# --- 火山对象存储 TOS ---（接入 adapter 时填入）
# TOS_ENDPOINT=
# TOS_REGION=
# TOS_BUCKET=
# TOS_ACCESS_KEY=
# TOS_SECRET_KEY=
